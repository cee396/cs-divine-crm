generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/tax-deed-crm-final/app/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  callLogs  CallLog[]
  csvImports CsvImport[]
  
  @@map("users")
}

model Property {
  id              Int      @id @default(autoincrement())
  parcelId        String   @unique
  address         String
  city            String
  county          String
  state           String   @default("FL")
  zipCode         String
  ownerName       String
  ownerAddress    String?
  assessedValue   Float
  taxesOwed       Float
  auctionDate     DateTime?
  minimumBid      Float?
  propertyType    String
  squareFootage   Int?
  bedrooms        Int?
  bathrooms       Float?
  yearBuilt       Int?
  lotSize         Float?
  description     String?
  status          String   @default("available") // available, sold, pending
  countyUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  leads           Lead[]
  
  @@map("properties")
}

model Lead {
  id              Int      @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  propertyId      Int?
  source          String   @default("csv_import") // csv_import, manual, web_form
  status          String   @default("new") // new, contacted, interested, not_interested, callback, closed
  priority        String   @default("medium") // low, medium, high
  notes           String?
  lastContactDate DateTime?
  nextFollowUp    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  property        Property? @relation(fields: [propertyId], references: [id])
  callLogs        CallLog[]
  
  @@map("leads")
}

model CallLog {
  id          Int      @id @default(autoincrement())
  leadId      Int
  userId      Int
  callType    String   // outbound, inbound
  duration    Int?     // in seconds
  outcome     String   // answered, voicemail, busy, no_answer, interested, not_interested
  notes       String?
  followUpDate DateTime?
  createdAt   DateTime @default(now())
  
  // Relations
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
  
  @@map("call_logs")
}

model CsvImport {
  id            Int      @id @default(autoincrement())
  fileName      String
  userId        Int
  totalRows     Int
  successRows   Int
  errorRows     Int
  errors        String?  // JSON string of errors
  status        String   @default("processing") // processing, completed, failed
  createdAt     DateTime @default(now())
  
  // Relations
  user          User     @relation(fields: [userId], references: [id])
  
  @@map("csv_imports")
}
